@prefix base: <https://example.org/ontology/base#> .
@prefix req:  <https://example.org/ontology/requirements#> .
@prefix size: <https://example.org/ontology/size#> .
@prefix cost: <https://example.org/ontology/cost#> .
@prefix risk: <https://example.org/ontology/risk#> .
@prefix price: <https://example.org/ontology/pricing#> .
@prefix quote: <https://example.org/ontology/quote#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### 15 confirmed classes
base:Project a owl:Class .
req:RequirementSet a owl:Class .
req:Requirement a owl:Class .
base:Assumption a owl:Class .
base:Constraint a owl:Class .
size:SizeEstimate a owl:Class .
cost:CostEstimate a owl:Class .
cost:LaborCost a owl:Class ; rdfs:subClassOf cost:CostEstimate .
cost:RateCard a owl:Class .
risk:RiskItem a owl:Class .
risk:RiskScore a owl:Class .
price:PricingPolicy a owl:Class .
quote:Quote a owl:Class .
quote:QuoteVersion a owl:Class ; rdfs:subClassOf prov:Entity .
quote:EstimateRange a owl:Class .

### confirmed object properties
req:belongsToSet a owl:ObjectProperty ; rdfs:domain req:Requirement ; rdfs:range req:RequirementSet .
req:drivesSize a owl:ObjectProperty ; rdfs:domain req:Requirement ; rdfs:range size:SizeEstimate .
size:informsCost a owl:ObjectProperty ; rdfs:domain size:SizeEstimate ; rdfs:range cost:CostEstimate .
cost:usesRateCard a owl:ObjectProperty ; rdfs:domain cost:LaborCost ; rdfs:range cost:RateCard .
price:pricedBy a owl:ObjectProperty ; rdfs:domain cost:CostEstimate ; rdfs:range price:PricingPolicy .
risk:aggregatedInto a owl:ObjectProperty ; rdfs:domain risk:RiskItem ; rdfs:range risk:RiskScore .
risk:adjustsRange a owl:ObjectProperty ; rdfs:domain risk:RiskScore ; rdfs:range quote:EstimateRange .
quote:hasVersion a owl:ObjectProperty ; rdfs:domain quote:Quote ; rdfs:range quote:QuoteVersion .
quote:hasQuote a owl:ObjectProperty ; rdfs:domain base:Project ; rdfs:range quote:Quote .
quote:derivedFromRequirementSet a owl:ObjectProperty ; rdfs:domain quote:QuoteVersion ; rdfs:range req:RequirementSet .
quote:usesAssumption a owl:ObjectProperty ; rdfs:domain quote:QuoteVersion ; rdfs:range base:Assumption .

### required datatype properties
req:statement a owl:DatatypeProperty ; rdfs:domain req:Requirement ; rdfs:range xsd:string .
req:testability a owl:DatatypeProperty ; rdfs:domain req:Requirement ; rdfs:range xsd:string .
cost:rateYear a owl:DatatypeProperty ; rdfs:domain cost:LaborCost ; rdfs:range xsd:gYear .
cost:rateSource a owl:DatatypeProperty ; rdfs:domain cost:LaborCost ; rdfs:range xsd:anyURI .
cost:pointCost a owl:DatatypeProperty ; rdfs:domain cost:CostEstimate ; rdfs:range xsd:decimal .
quote:versionNo a owl:DatatypeProperty ; rdfs:domain quote:QuoteVersion ; rdfs:range xsd:integer .
quote:generatedAt a owl:DatatypeProperty ; rdfs:domain quote:QuoteVersion ; rdfs:range xsd:dateTime .
quote:min a owl:DatatypeProperty ; rdfs:domain quote:EstimateRange ; rdfs:range xsd:decimal .
quote:p50 a owl:DatatypeProperty ; rdfs:domain quote:EstimateRange ; rdfs:range xsd:decimal .
quote:p80 a owl:DatatypeProperty ; rdfs:domain quote:EstimateRange ; rdfs:range xsd:decimal .
quote:max a owl:DatatypeProperty ; rdfs:domain quote:EstimateRange ; rdfs:range xsd:decimal .

